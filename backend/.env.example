# Copia como backend/.env o usa el .env de la raíz del proyecto (ambos funcionan)

SUPABASE_DB_HOST=db.TU_PROYECTO.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=tu_password_de_supabase
SUPABASE_DB_SSLMODE=require

# JWT de la aplicación (NO es el JWT Secret de Supabase)
JWT_SECRET=clave-secreta-larga-y-segura-para-jwt-minimo-32-caracteres
CORS_ORIGINS=http://localhost:4200

# NOTA: Project URL, anon key y service_role de Supabase NO se usan aquí.
# Spring Boot se conecta directo a PostgreSQL por JDBC, no por la API REST de Supabase.
